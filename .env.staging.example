# ═══════════════════════════════════════════
# UniHR SaaS — Staging
# ═══════════════════════════════════════════
APP_ENV=staging
SECRET_KEY=CHANGE_THIS_STAGING_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging_password_change_me
POSTGRES_DB=unihr_saas_staging
POSTGRES_SSL_MODE=prefer
RLS_ENFORCEMENT_ENABLED=true
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_FAIL_CLOSED=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# CORS
BACKEND_CORS_ORIGINS=https://staging.unihr.example.com

# Core API
CORE_API_URL=https://core-staging.unihr.example.com
CORE_SERVICE_TOKEN=

# LLM Backend
LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1500
SOURCE_PRIORITY_MODE=adaptive
POLICY_SOURCE_WEIGHT=0.65
LAW_SOURCE_WEIGHT=0.35
CONFLICT_RESOLUTION_MODE=legal_floor

# Ollama (when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:27b
OLLAMA_API_KEY=ollama

# AI / Vector (Voyage AI + pgvector)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-4-lite

# SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SSO_DEFAULT_REDIRECT_URI=https://staging.unihr.example.com/login/callback
