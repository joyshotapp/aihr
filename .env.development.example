# ═══════════════════════════════════════════
# UniHR SaaS — Development (default)
# ═══════════════════════════════════════════
APP_ENV=development
SECRET_KEY=dev-secret-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=unihr_saas

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# Core API
CORE_API_URL=http://localhost:5000
CORE_SERVICE_TOKEN=

# LLM Backend
LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1500
SOURCE_PRIORITY_MODE=adaptive
POLICY_SOURCE_WEIGHT=0.65
LAW_SOURCE_WEIGHT=0.35
CONFLICT_RESOLUTION_MODE=legal_floor

# Ollama (when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:27b
OLLAMA_API_KEY=ollama

# AI / Vector (Voyage AI + pgvector)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-4-lite

# SSO (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SSO_DEFAULT_REDIRECT_URI=http://localhost:3001/login/callback
